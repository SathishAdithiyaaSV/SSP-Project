FROM python:3.11-slim

WORKDIR /workspace

COPY hotelReservation/sandboxing/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY hotelReservation /workspace/hotelReservation

ENV PYTHONPATH=/workspace

CMD ["python", "-m", "hotelReservation.sandboxing.dummy_server", "--help"]
